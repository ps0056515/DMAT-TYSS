# Server
PORT=3001

# SQLite — no Docker required. Path is relative to packages/database/prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"

# App URLs (local dev)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_PUBLIC_SITE_URL="http://localhost:3100"
NEXT_PUBLIC_CANDIDATE_PORTAL_URL="http://localhost:3200"

# Data residency default region
DEFAULT_DATA_REGION="eu-central-1"

# Optional (not required for local dev)
# REDIS_URL="redis://localhost:6379"
# S3_ENDPOINT="http://localhost:9000"
